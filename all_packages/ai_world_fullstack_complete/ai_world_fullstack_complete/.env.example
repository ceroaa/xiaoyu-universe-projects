APP_NAME=AI World API
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
POSTGRES_DB=ai_world
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ai_world
AUTO_SEED=true
AUTO_SEED_MORE=true
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen2.5:7b-instruct
LLM_PROVIDER=openai
