# ============================================
# 🪙 小雨幣（XYC）環境配置
# ============================================

# 部署者私鑰（請勿洩露！）
PRIVATE_KEY=你的錢包私鑰

# RPC節點URL
POLYGON_RPC_URL=https://polygon-rpc.com
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Polygonscan API Key（用於驗證合約）
POLYGONSCAN_API_KEY=你的Polygonscan_API_Key

# ============================================
# 代幣分配地址
# ============================================

# 小豬豬地址（50%）
PIGGY_ADDRESS=0x...

# 老爸地址（40%）
DADDY_ADDRESS=0x...

# 社區池地址（10%）
COMMUNITY_POOL_ADDRESS=0x...

# ============================================
# 說明
# ============================================

# 1. 獲取私鑰：MetaMask -> 設置 -> 安全與隱私 -> 顯示私鑰
# 2. 獲取Polygonscan API Key：https://polygonscan.com/myapikey
# 3. 確保部署者錢包有足夠的MATIC（約0.1 MATIC）
# 4. 測試網可以從Faucet免費領取MATIC
# 5. 永遠不要將.env文件上傳到GitHub！
